    "allowedReasoningPacks": [],
    "allowedCapabilities": [{ "id": "urn:faf:capability:edit-files", "version": "1.0.0" }],
    "allowedTools": [{ "id": "urn:faf:tool:workspace-editor", "version": "1.0.0" }],
