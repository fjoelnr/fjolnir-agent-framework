{
  "specVersion": "1.0",
  "kind": "AgentContract",
  "id": "urn:faf:contract:agent:reference-engineer",
  "version": "1.0.0",
  "metadata": { "name": "Reference Engineering Agent Contract", "lifecycle": "experimental" },
  "spec": {
    "purpose": "Perform bounded repository changes with reviewable validation.",
    "role": { "id": "urn:faf:role:software-engineer", "version": "1.0.0" },
    "allowedPolicies": [],
