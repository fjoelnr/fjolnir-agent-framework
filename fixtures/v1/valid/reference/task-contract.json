{
  "specVersion": "1.0",
  "kind": "TaskContract",
  "id": "urn:faf:contract:task:update-docs",
  "version": "1.0.0",
  "metadata": { "name": "Update architecture documentation", "lifecycle": "experimental" },
  "spec": {
    "agentContract": { "id": "urn:faf:contract:agent:reference-engineer", "version": "1.0.0" },
    "taskType": "documentation-change",
    "objective": "Update architecture documentation consistently.",
    "context": "A bounded documentation-only change.",
    "inputs": ["Repository documentation"],
    "constraints": ["Do not modify implementation files"],
    "acceptanceCriteria": ["Local Markdown links resolve", "Documents use canonical terminology"],
    "riskLevel": "low",
    "requestedCapabilities": [{ "id": "urn:faf:capability:edit-files", "version": "1.0.0" }],
    "requestedTools": [{ "id": "urn:faf:tool:workspace-editor", "version": "1.0.0" }],
    "requiredOutput": "markdown-report",
    "qualityGates": [{ "id": "urn:faf:gate:scope-and-evidence", "version": "1.0.0" }],
    "escalationConditions": ["Requested work exceeds documentation scope"]
  }
}
